{
  "properties": {
    "displayName": "Virtual Network should Specify the allowed service delegations for subnets",
    "policyType": "BuiltIn",
    "mode": "All",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. Restricts which Azure services can be delegated control of subnets to ensure only approved services can inject resources into the virtual network.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Virtual Network should Specify the allowed service delegations for subnets Effect",
          "description": " Specify the allowed service delegations for subnets Effect"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "allowedServiceNames": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed Service Names for Delegation",
          "description": " Allowed Service Names for Delegation. Example: Microsoft.Web/serverFarms, Microsoft.Synapse/workspaces"
        },
        "defaultValue": []
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "in": [
              "Microsoft.Network/virtualNetworks",
              "Microsoft.Network/virtualNetworks/subnets"
            ]
          },
          {
            "anyOf": [
              {
                "allOf": [
                  {
                    "field": "type",
                    "equals": "Microsoft.Network/virtualNetworks/subnets"
                  },
                  {
                    "count": {
                      "field": "Microsoft.Network/virtualNetworks/subnets/delegations[*]",
                      "where": {
                        "value": "[current('Microsoft.Network/virtualNetworks/subnets/delegations[*].serviceName')]",
                        "notIn": "[parameters('allowedServiceNames')]"
                      }
                    },
                    "greater": 0
                  }
                ]
              },
              {
                "allOf": [
                  {
                    "field": "type",
                    "equals": "Microsoft.Network/virtualNetworks"
                  },
                  {
                    "count": {
                      "field": "Microsoft.Network/virtualNetworks/subnets[*]",
                      "where": {
                        "count": {
                          "field": "Microsoft.Network/virtualNetworks/subnets[*].delegations[*]",
                          "where": {
                            "value": "[current('Microsoft.Network/virtualNetworks/subnets[*].delegations[*].serviceName')]",
                            "notIn": "[parameters('allowedServiceNames')]"
                          }
                        },
                        "greater": 0
                      }
                    },
                    "greater": 0
                  }
                ]
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/7ecf8dcc-8f39-4225-9ff8-06a8e75d778b",
  "name": "7ecf8dcc-8f39-4225-9ff8-06a8e75d778b"
}