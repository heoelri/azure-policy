{
  "properties": {
    "displayName": "Virtual Network should Deny private endpoints linked to services in other tenants",
    "policyType": "BuiltIn",
    "mode": "All",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. Prevents private endpoints from connecting to services in other Azure AD tenants to ensure data doesn't leave the organization's control and reduce the risk of data exfiltration.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "exemptPeExternalSubIds": {
        "type": "Array",
        "metadata": {
          "displayName": "Exempt Private Endpoint External Subscription IDs",
          "description": "List of external subscription IDs that are exempted from the policy"
        },
        "defaultValue": []
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Network/privateEndpoints"
          },
          {
            "anyOf": [
              {
                "count": {
                  "field": "Microsoft.Network/privateEndpoints/manualprivateLinkServiceConnections[*]",
                  "where": {
                    "allOf": [
                      {
                        "field": "Microsoft.Network/privateEndpoints/manualprivateLinkServiceConnections[*].privateLinkServiceId",
                        "notEquals": ""
                      },
                      {
                        "value": "[split(concat(current('Microsoft.Network/privateEndpoints/manualprivateLinkServiceConnections[*].privateLinkServiceId'), '//'), '/')[2]]",
                        "notEquals": "[subscription().subscriptionId]"
                      },
                      {
                        "not": {
                          "value": "[split(concat(current('Microsoft.Network/privateEndpoints/manualprivateLinkServiceConnections[*].privateLinkServiceId'), '//'), '/')[2]]",
                          "in": "[parameters('exemptPeExternalSubIds')]"
                        }
                      }
                    ]
                  }
                },
                "greaterOrEquals": 1
              },
              {
                "count": {
                  "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*]",
                  "where": {
                    "allOf": [
                      {
                        "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].privateLinkServiceId",
                        "notEquals": ""
                      },
                      {
                        "value": "[split(concat(current('Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].privateLinkServiceId'), '//'), '/')[2]]",
                        "notEquals": "[subscription().subscriptionId]"
                      },
                      {
                        "not": {
                          "value": "[split(concat(current('Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].privateLinkServiceId'), '//'), '/')[2]]",
                          "in": "[parameters('exemptPeExternalSubIds')]"
                        }
                      }
                    ]
                  }
                },
                "greaterOrEquals": 1
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/ee59ea13-92cf-4d3f-acf4-009bf9702aab",
  "name": "ee59ea13-92cf-4d3f-acf4-009bf9702aab"
}