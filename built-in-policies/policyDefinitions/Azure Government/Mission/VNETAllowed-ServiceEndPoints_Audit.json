{
  "properties": {
    "displayName": "Virtual Network should specify allowed service endpoints",
    "policyType": "BuiltIn",
    "mode": "All",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. Restricts which Azure service endpoints can be enabled on subnets to reduce the attack surface and ensure only approved services can be accessed from the virtual network.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "allowedServiceTypes": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed Service Endpoint Service Types",
          "description": " Allowed Service Endpoint Service Types for Subnets. Example: Microsoft.Storage, Microsoft.KeyVault"
        },
        "defaultValue": []
      },
      "subnetDelegationsToExclude": {
        "type": "Array",
        "metadata": {
          "displayName": "Subnet Delegations to Exclude",
          "description": " Exclude Subnets which have specific Subnet Delegations (ex. Microsoft.ApiManagement/service)"
        },
        "defaultValue": []
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "in": [
              "Microsoft.Network/virtualNetworks",
              "Microsoft.Network/virtualNetworks/subnets"
            ]
          },
          {
            "anyOf": [
              {
                "allOf": [
                  {
                    "field": "type",
                    "equals": "Microsoft.Network/virtualNetworks/subnets"
                  },
                  {
                    "count": {
                      "field": "Microsoft.Network/virtualNetworks/subnets/serviceEndpoints[*]",
                      "where": {
                        "value": "[current('Microsoft.Network/virtualNetworks/subnets/serviceEndpoints[*].service')]",
                        "notIn": "[parameters('allowedServiceTypes')]"
                      }
                    },
                    "greater": 0
                  },
                  {
                    "count": {
                      "field": "Microsoft.Network/virtualNetworks/subnets/delegations[*]",
                      "where": {
                        "field": "Microsoft.Network/virtualNetworks/subnets/delegations[*].serviceName",
                        "in": "[parameters('subnetDelegationsToExclude')]"
                      }
                    },
                    "equals": 0
                  }
                ]
              },
              {
                "allOf": [
                  {
                    "field": "type",
                    "equals": "Microsoft.Network/virtualNetworks"
                  },
                  {
                    "count": {
                      "field": "Microsoft.Network/virtualNetworks/subnets[*]",
                      "where": {
                        "allOf": [
                          {
                            "count": {
                              "field": "Microsoft.Network/virtualNetworks/subnets[*].serviceEndpoints[*]",
                              "where": {
                                "value": "[current('Microsoft.Network/virtualNetworks/subnets[*].serviceEndpoints[*].service')]",
                                "notIn": "[parameters('allowedServiceTypes')]"
                              }
                            },
                            "greater": 0
                          },
                          {
                            "count": {
                              "field": "Microsoft.Network/virtualNetworks/subnets[*].delegations[*]",
                              "where": {
                                "field": "Microsoft.Network/virtualNetworks/subnets[*].delegations[*].serviceName",
                                "in": "[parameters('subnetDelegationsToExclude')]"
                              }
                            },
                            "equals": 0
                          }
                        ]
                      }
                    },
                    "greater": 0
                  }
                ]
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/918dcd3f-28e6-4fa5-8373-44919b46c98e",
  "name": "918dcd3f-28e6-4fa5-8373-44919b46c98e"
}