{
  "properties": {
    "displayName": "Control the use of Virtual Network Guardrails for Cloud in Mission Platforms",
    "policyType": "BuiltIn",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. This policy set deploys the required policy guardrails governing the use of Azure Virtual Networks within the Environment. See the list of policies of the services that are included.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "svcEndpoints_allowedServiceTypes": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed Service end points service types",
          "description": "Enable or disable allowed service endpoint service types"
        },
        "defaultValue": []
      },
      "svcEndpoints_subnetDelegationsToExclude": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed Service end points excluded subnet delegation effect",
          "description": "Enable or disable allowed service endpoint subnet delegation exclusion"
        },
        "defaultValue": []
      },
      "svcDelegations_allowedServiceNames": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed Service delegation service names effect",
          "description": "Enable or disable allowed Service delegation service names"
        },
        "defaultValue": [
          "Microsoft.Web/serverfarms",
          "Microsoft.DBforPostgreSQL/flexibleServers",
          "Microsoft.ContainerService/managedClusters",
          "Microsoft.Web/hostingEnvironments",
          "Microsoft.ContainerInstance/containerGroups",
          "Microsoft.ApiManagement/service"
        ]
      },
      "allowedVnetPeers": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed vnet peers List effect",
          "description": "Enable or disable allowed listed vnet peers"
        },
        "defaultValue": []
      },
      "exemptPeExternalSubIds": {
        "type": "Array",
        "defaultValue": [],
        "metadata": {
          "displayName": "Exempt PE External Subscription IDs",
          "description": "List of subscription IDs exempt from private endpoint external restrictions"
        }
      }
    },
    "policyDefinitions": [
      {
        "policyDefinitionReferenceId": "VNETAllowedServiceEndPoints",
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/918dcd3f-28e6-4fa5-8373-44919b46c98e",
        "definitionVersion": "1.*.*",
        "parameters": {
          "allowedServiceTypes": {
            "value": "[parameters('svcEndpoints_allowedServiceTypes')]"
          },
          "subnetDelegationsToExclude": {
            "value": "[parameters('svcEndpoints_subnetDelegationsToExclude')]"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/7ecf8dcc-8f39-4225-9ff8-06a8e75d778b",
        "policyDefinitionReferenceId": "VNETAllowedServiceDelegation",
        "definitionVersion": "1.*.*",
        "parameters": {
          "allowedServiceNames": {
            "value": "[parameters('svcDelegations_allowedServiceNames')]"
          }
        }
      },
      {
        "policyDefinitionReferenceId": "VNETAllowedPeers",
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/9de54b0f-202f-41c3-8c4f-c27a89bc3b57",
        "definitionVersion": "1.*.*",
        "parameters": {
          "allowedVnetPeers": {
            "value": "[parameters('allowedVnetPeers')]"
          }
        }
      },
      {
        "policyDefinitionReferenceId": "VNETRequirePrivateSubnet",
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/a6d35950-ad6c-46f8-994d-0d236eae0699",
        "definitionVersion": "1.*.*"
      },
      {
        "policyDefinitionReferenceId": "VNETRestrictInternalPe",
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/ee59ea13-92cf-4d3f-acf4-009bf9702aab",
        "definitionVersion": "1.*.*",
        "parameters": {
          "exemptPeExternalSubIds": {
            "value": "[parameters('exemptPeExternalSubIds')]"
          }
        }
      }
    ],
    "versions": [
      "1.0.0"
    ]
  },
